{{ $runtimeFlags := .runtime_flags | default dict }}
{{ $hasSpecCode := index $runtimeFlags "has_spec" }}
{{ $hasLinkCode := index $runtimeFlags "has_link" }}
{{ $hasSwCode := index $runtimeFlags "has_sw" }}
{{ $hasLinkHoverCode := index $runtimeFlags "has_link_hover" }}
{{ $hasSwHoverCode := index $runtimeFlags "has_sw_hover" }}
{{ $hasHoverCode := or $hasLinkHoverCode $hasSwHoverCode }}
{{ $envKey := upper (printf "%v" (.env_sequence | default "")) }}
(function () {
    const actionsNode = document.getElementById('site-prefetch-actions');
    if (!actionsNode) return;

    let actionsByEnv = null;
    try {
        actionsByEnv = JSON.parse(actionsNode.textContent || '{}');
    } catch (error) {
        return;
    }

    const actions = actionsByEnv && typeof actionsByEnv === 'object' ? actionsByEnv[{{ $envKey | jsonify }}] || null : null;
    if (!actions || typeof actions !== 'object') return;

    {{ if $hasSpecCode }}
    const speculationRulesPayload = actions.speculation_rules_payload && typeof actions.speculation_rules_payload === 'object'
        ? actions.speculation_rules_payload
        : null;
    const hasSpec = !!(speculationRulesPayload && Object.keys(speculationRulesPayload).length);
    {{ else }}
    const hasSpec = false;
    {{ end }}

    {{ if $hasLinkCode }}
    const linkStaticUrls = Array.isArray(actions.link_static_urls) ? actions.link_static_urls : [];
    const linkHoverImmediateUrls = Array.isArray(actions.link_hover_immediate_urls) ? actions.link_hover_immediate_urls : [];
    const linkHoverDelayedUrls = Array.isArray(actions.link_hover_delayed_urls) ? actions.link_hover_delayed_urls : [];
    const hasLinkHover = linkHoverImmediateUrls.length > 0 || linkHoverDelayedUrls.length > 0;
    const hasLink = linkStaticUrls.length > 0 || hasLinkHover;
    {{ else }}
    const hasLinkHover = false;
    const hasLink = false;
    {{ end }}

    {{ if $hasSwCode }}
    const swStaticUrls = Array.isArray(actions.sw_static_urls) ? actions.sw_static_urls : [];
    const swHoverImmediateUrls = Array.isArray(actions.sw_hover_immediate_urls) ? actions.sw_hover_immediate_urls : [];
    const swHoverDelayedUrls = Array.isArray(actions.sw_hover_delayed_urls) ? actions.sw_hover_delayed_urls : [];
    const hasSwHover = swHoverImmediateUrls.length > 0 || swHoverDelayedUrls.length > 0;
    const hasSw = swStaticUrls.length > 0 || hasSwHover;
    {{ else }}
    const hasSwHover = false;
    const hasSw = false;
    {{ end }}

    if (!hasSpec && !hasLink && !hasSw) return;

    {{ if or $hasLinkCode $hasSwCode }}
    function normalizeNavigationUrl(rawUrl) {
        try {
            const url = new URL(rawUrl, window.location.href);
            if (!/^https?:$/.test(url.protocol)) return '';
            if (url.origin !== window.location.origin) return '';
            url.hash = '';
            return url.toString();
        } catch (error) {
            return '';
        }
    }
    {{ end }}

    {{ if or $hasLinkCode $hasSwCode }}
    const warmedNavigationUrls = new Set();
    {{ end }}

    {{ if $hasLinkCode }}
    function ensurePrefetchLink(rawUrl) {
        const href = normalizeNavigationUrl(rawUrl);
        if (!href || warmedNavigationUrls.has(href)) return false;
        warmedNavigationUrls.add(href);

        const link = document.createElement('link');
        link.rel = 'prefetch';
        link.href = href;
        link.setAttribute('data-prefetch-link', 'runtime');
        document.head.appendChild(link);
        return true;
    }
    {{ end }}

    {{ if $hasSwCode }}
    async function warmServiceWorkerUrls(rawUrls) {
        const queuedUrls = [];
        for (const rawUrl of rawUrls) {
            const href = normalizeNavigationUrl(rawUrl);
            if (!href || warmedNavigationUrls.has(href)) continue;
            warmedNavigationUrls.add(href);
            queuedUrls.push(href);
        }
        if (!queuedUrls.length) return;

        try {
            const registration = await navigator.serviceWorker.ready;
            const worker = registration?.active;
            if (!worker) {
                queuedUrls.forEach((href) => warmedNavigationUrls.delete(href));
                return;
            }

            worker.postMessage({
                type: 'WARM_NAV_BATCH',
                urls: queuedUrls
            });
        } catch (error) {
            queuedUrls.forEach((href) => warmedNavigationUrls.delete(href));
        }
    }
    {{ end }}

    {{ if $hasSpecCode }}
    if (hasSpec) {
        const speculationRulesScript = document.createElement('script');
        speculationRulesScript.type = 'speculationrules';
        speculationRulesScript.setAttribute('data-prefetch-generated', 'runtime');
        speculationRulesScript.textContent = JSON.stringify(speculationRulesPayload);
        document.head.appendChild(speculationRulesScript);
    }
    {{ end }}

    {{ if $hasLinkCode }}
    if (hasLink) {
        for (const href of linkStaticUrls) {
            ensurePrefetchLink(href);
        }
    }
    {{ end }}

    {{ if $hasSwCode }}
    if (swStaticUrls.length > 0) {
        void warmServiceWorkerUrls(swStaticUrls);
    }
    {{ end }}

    {{ if $hasHoverCode }}
    if (hasLinkHover || hasSwHover) {
    const HOVER_WARM_DELAY_MS = 65;
    const hoverTargets = new Map();
    let hoverWarmTimer = null;
    let hoverWarmAnchor = null;

    function registerHoverTargets(rawUrls, transport, action) {
        for (const rawUrl of rawUrls) {
            const href = normalizeNavigationUrl(rawUrl);
            if (!href || hoverTargets.has(href)) continue;
            hoverTargets.set(href, { transport, action });
        }
    }

    {{ if $hasLinkCode }}
    registerHoverTargets(linkHoverImmediateUrls, 'link', 'immediate');
    registerHoverTargets(linkHoverDelayedUrls, 'link', 'delayed');
    {{ end }}
    {{ if $hasSwCode }}
    registerHoverTargets(swHoverImmediateUrls, 'sw', 'immediate');
    registerHoverTargets(swHoverDelayedUrls, 'sw', 'delayed');
    {{ end }}

    function warmNavigationUrls(transport, rawUrls) {
        if (transport === 'link') {
            for (const rawUrl of rawUrls) {
                ensurePrefetchLink(rawUrl);
            }
            return;
        }

        if (transport === 'sw') {
            void warmServiceWorkerUrls(rawUrls);
        }
    }

    function getAnchorWarmTarget(anchor) {
        if (!(anchor instanceof HTMLAnchorElement)) return null;
        if (anchor.target && anchor.target.toLowerCase() !== '_self') return null;
        if (anchor.hasAttribute('download')) return null;

        const href = normalizeNavigationUrl(anchor.href);
        if (!href) return null;
        return hoverTargets.get(href) || null;
    }

    function maybeWarmNavigationAnchor(anchor) {
        const target = getAnchorWarmTarget(anchor);
        if (!target) return;
        warmNavigationUrls(target.transport, [anchor.href]);
    }

    function clearHoverWarmTimer() {
        if (hoverWarmTimer) {
            window.clearTimeout(hoverWarmTimer);
            hoverWarmTimer = null;
        }
        hoverWarmAnchor = null;
    }

    function scheduleHoverWarm(anchor) {
        const target = getAnchorWarmTarget(anchor);
        if (!target) {
            clearHoverWarmTimer();
            return;
        }

        if (target.action === 'immediate') {
            clearHoverWarmTimer();
            maybeWarmNavigationAnchor(anchor);
            return;
        }

        if (hoverWarmAnchor === anchor && hoverWarmTimer) return;

        clearHoverWarmTimer();
        hoverWarmAnchor = anchor;
        hoverWarmTimer = window.setTimeout(() => {
            const pendingAnchor = hoverWarmAnchor;
            hoverWarmTimer = null;
            hoverWarmAnchor = null;
            if (pendingAnchor) {
                maybeWarmNavigationAnchor(pendingAnchor);
            }
        }, HOVER_WARM_DELAY_MS);
    }

    document.addEventListener('mouseover', (event) => {
        const anchor = event.target instanceof Element ? event.target.closest('a[href]') : null;
        if (anchor instanceof HTMLAnchorElement) {
            scheduleHoverWarm(anchor);
            return;
        }

        clearHoverWarmTimer();
    }, true);

    document.addEventListener('mouseout', (event) => {
        if (!hoverWarmAnchor) return;

        const anchor = event.target instanceof Element ? event.target.closest('a[href]') : null;
        if (anchor !== hoverWarmAnchor) return;

        const related = event.relatedTarget instanceof Node ? event.relatedTarget : null;
        if (related && hoverWarmAnchor.contains(related)) return;
        clearHoverWarmTimer();
    }, true);

    document.addEventListener('focusin', (event) => {
        const anchor = event.target instanceof Element ? event.target.closest('a[href]') : null;
        if (anchor instanceof HTMLAnchorElement) {
            maybeWarmNavigationAnchor(anchor);
        }
    }, true);

    document.addEventListener('touchstart', (event) => {
        const anchor = event.target instanceof Element ? event.target.closest('a[href]') : null;
        if (anchor instanceof HTMLAnchorElement) {
            maybeWarmNavigationAnchor(anchor);
        }
    }, { capture: true, passive: true });
    }
    {{ end }}

    const activeTransports = [];
    if (hasSpec) activeTransports.push('speculationrules');
    if (hasLink) activeTransports.push('link');
    if (hasSw) activeTransports.push('sw');
    document.documentElement.setAttribute('data-prefetch-runtime', activeTransports.join(' '));
})();
