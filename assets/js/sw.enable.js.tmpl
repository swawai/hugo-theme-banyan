const NAVIGATION_CACHE_PREFIX = 'nav-html-';
const VERSIONED_ASSET_CACHE_PREFIX = 'asset-versioned-';
const LEGACY_VERSIONED_ASSET_CACHE_PREFIX = 'asset-static-';
const FINGERPRINT_ASSET_CACHE = 'asset-fingerprint';
const NAVIGATION_CACHE = NAVIGATION_CACHE_PREFIX + '{{ .build_version }}';
const VERSIONED_ASSET_CACHE = VERSIONED_ASSET_CACHE_PREFIX + '{{ .build_version }}';
const OFFLINE_FALLBACKS = {{ .offline_fallbacks | jsonify }};
const SW_ROUTES = {{ .sw_routes | jsonify }};
const navigationWarmupTasks = new Map();

function isSameOriginRequest(request) {
    try {
        return new URL(request.url).origin === self.location.origin;
    } catch (error) {
        return false;
    }
}

function acceptsHtmlDocument(request) {
    try {
        const accept = request.headers.get('accept') || '';
        return accept.includes('text/html');
    } catch (error) {
        return false;
    }
}

function isHtmlDocumentRequest(request) {
    if (request.method !== 'GET') return false;
    if (!isSameOriginRequest(request)) return false;
    if (request.mode === 'navigate') return true;
    if (request.destination === 'document') return true;
    return acceptsHtmlDocument(request);
}

function isCacheableHtmlResponse(response) {
    return response && response.ok && response.headers.get('content-type')?.includes('text/html');
}

function isCacheableAssetResponse(response) {
    return response && response.ok;
}

function getRequestPathname(request) {
    try {
        return new URL(request.url).pathname.toLowerCase();
    } catch (error) {
        return '';
    }
}

function isEligibleAssetRequest(request) {
    if (request.method !== 'GET') return false;
    if (!isSameOriginRequest(request)) return false;
    if (isHtmlDocumentRequest(request)) return false;
    return true;
}

function normalizeRoutePath(pathValue) {
    return typeof pathValue === 'string' ? pathValue.toLowerCase() : '';
}

function matchesRoutePath(routePath, pathname) {
    const normalizedRoutePath = normalizeRoutePath(routePath);
    if (!normalizedRoutePath || !pathname) return false;
    if (normalizedRoutePath === '/*') return true;
    if (normalizedRoutePath.endsWith('/*')) {
        return pathname.startsWith(normalizedRoutePath.slice(0, -1));
    }
    return pathname === normalizedRoutePath;
}

function getMatchingRoute(scope, pathname) {
    let defaultRoute = null;

    for (const route of SW_ROUTES) {
        if (!route || typeof route !== 'object') continue;
        const routeScope = typeof route.scope === 'string' ? route.scope.toLowerCase() : '';
        if (routeScope === 'default' && !defaultRoute && matchesRoutePath(route.path, pathname)) {
            defaultRoute = route;
            continue;
        }
        if (routeScope === scope && matchesRoutePath(route.path, pathname)) {
            return route;
        }
    }

    return defaultRoute;
}

function shouldHandleRoute(route) {
    return route && route.mode === 'cache-first';
}

function getCacheNameForRoute(route) {
    if (!route) return '';
    if (route.bucket === 'fingerprinted') return FINGERPRINT_ASSET_CACHE;
    if (route.bucket === 'versioned') {
        return route.scope === 'navigation' ? NAVIGATION_CACHE : VERSIONED_ASSET_CACHE;
    }
    return '';
}

function isManagedCacheKey(key) {
    return key === FINGERPRINT_ASSET_CACHE
        || key.startsWith(NAVIGATION_CACHE_PREFIX)
        || key.startsWith(VERSIONED_ASSET_CACHE_PREFIX)
        || key.startsWith(LEGACY_VERSIONED_ASSET_CACHE_PREFIX);
}

function shouldDeleteOnActivate(key) {
    if (key.startsWith(NAVIGATION_CACHE_PREFIX)) return key !== NAVIGATION_CACHE;
    if (key.startsWith(VERSIONED_ASSET_CACHE_PREFIX)) return key !== VERSIONED_ASSET_CACHE;
    if (key.startsWith(LEGACY_VERSIONED_ASSET_CACHE_PREFIX)) return true;
    return false;
}

async function fetchNavigationResponse(request, preloadResponsePromise) {
    if (preloadResponsePromise) {
        try {
            const preloadResponse = await preloadResponsePromise;
            if (preloadResponse) return preloadResponse;
        } catch (error) { }
    }

    return fetch(request);
}

function normalizeWarmNavigationUrl(urlValue) {
    try {
        const url = new URL(urlValue, self.location.origin);
        if (url.origin !== self.location.origin) return '';
        url.hash = '';
        return url.toString();
    } catch (error) {
        return '';
    }
}

function normalizePathnameForPrefixMatch(pathname) {
    if (typeof pathname !== 'string' || !pathname) return '/';
    if (pathname === '/') return '/';
    return pathname.endsWith('/') ? pathname : pathname + '/';
}

function getOfflineFallbackUrl(pathname) {
    const normalizedPathname = normalizePathnameForPrefixMatch(pathname);
    let matchedUrl = '';
    let matchedPrefixLength = -1;

    for (const fallback of OFFLINE_FALLBACKS) {
        if (!fallback || typeof fallback !== 'object') continue;

        const normalizedPrefix = normalizePathnameForPrefixMatch(
            typeof fallback.path_prefix === 'string' ? fallback.path_prefix.toLowerCase() : ''
        );
        const normalizedUrl = normalizeWarmNavigationUrl(fallback.url);

        if (!normalizedPrefix || !normalizedUrl) continue;
        if (!normalizedPathname.startsWith(normalizedPrefix)) continue;
        if (normalizedPrefix.length <= matchedPrefixLength) continue;

        matchedUrl = normalizedUrl;
        matchedPrefixLength = normalizedPrefix.length;
    }

    return matchedUrl;
}

function getOfflineFallbackUrls() {
    const urls = [];
    const seenUrls = new Set();

    for (const fallback of OFFLINE_FALLBACKS) {
        if (!fallback || typeof fallback !== 'object') continue;
        const normalizedUrl = normalizeWarmNavigationUrl(fallback.url);
        if (!normalizedUrl || seenUrls.has(normalizedUrl)) continue;
        seenUrls.add(normalizedUrl);
        urls.push(normalizedUrl);
    }

    return urls;
}

async function updateNavigationCache(request, cache, preloadResponsePromise) {
    try {
        let response = await fetchNavigationResponse(request, preloadResponsePromise);
        if (response && response.status === 304) {
            // Browser-level prefetch often revalidates from HTTP cache and returns 304.
            // SW cache needs a full body, so retry by bypassing the browser cache layer.
            response = await fetch(new Request(request, { cache: 'reload' }));
        }
        if (isCacheableHtmlResponse(response)) {
            await cache.put(request, response.clone());
        }
        return response;
    } catch (error) {
        return null;
    }
}

async function getOfflineFallbackResponse(pathname) {
    const offlineUrl = getOfflineFallbackUrl(pathname);
    if (!offlineUrl) return null;

    const cache = await caches.open(NAVIGATION_CACHE);
    const offlineRequest = new Request(offlineUrl, {
        credentials: 'same-origin',
        headers: {
            Accept: 'text/html'
        }
    });
    const cachedResponse = await cache.match(offlineRequest);
    if (cachedResponse) {
        return cachedResponse;
    }

    const networkResponse = await updateNavigationCache(offlineRequest, cache, null);
    if (isCacheableHtmlResponse(networkResponse)) {
        return networkResponse;
    }

    return null;
}

async function warmNavigationUrl(urlValue) {
    const href = normalizeWarmNavigationUrl(urlValue);
    if (!href) return;
    const pathname = getRequestPathname(new Request(href));
    const route = getMatchingRoute('navigation', pathname);
    if (!shouldHandleRoute(route)) return;

    if (navigationWarmupTasks.has(href)) {
        await navigationWarmupTasks.get(href);
        return;
    }

    const task = (async () => {
        const cache = await caches.open(getCacheNameForRoute(route));
        const request = new Request(href, {
            credentials: 'same-origin',
            headers: {
                Accept: 'text/html'
            }
        });
        const cachedResponse = await cache.match(request);
        if (cachedResponse) return;
        await updateNavigationCache(request, cache, null);
    })();

    navigationWarmupTasks.set(href, task);
    try {
        await task;
    } finally {
        navigationWarmupTasks.delete(href);
    }
}

async function warmNavigationUrls(urlValues) {
    for (const urlValue of urlValues) {
        await warmNavigationUrl(urlValue);
    }
}

self.addEventListener('install', (event) => {
    event.waitUntil(warmNavigationUrls(getOfflineFallbackUrls()));
});

async function handleNavigationRequest(request, preloadResponsePromise) {
    const pathname = getRequestPathname(request);
    const route = getMatchingRoute('navigation', pathname);
    if (!shouldHandleRoute(route)) {
        return fetchNavigationResponse(request, preloadResponsePromise);
    }

    const cache = await caches.open(getCacheNameForRoute(route));
    const cachedResponse = await cache.match(request);
    if (cachedResponse) {
        return cachedResponse;
    }

    const networkResponse = await updateNavigationCache(request, cache, preloadResponsePromise);
    if (networkResponse) {
        return networkResponse;
    }

    const offlineFallbackResponse = await getOfflineFallbackResponse(pathname);
    if (offlineFallbackResponse) {
        return offlineFallbackResponse;
    }

    throw new Error('Navigation request failed with no cached response.');
}

async function handleAssetRequest(request, pathname) {
    const route = getMatchingRoute('asset', pathname);
    if (!shouldHandleRoute(route)) {
        return fetch(request);
    }

    const cacheName = getCacheNameForRoute(route);
    if (!cacheName) {
        return fetch(request);
    }

    const cache = await caches.open(cacheName);
    const cachedResponse = await cache.match(request);
    if (cachedResponse) {
        return cachedResponse;
    }

    const networkResponse = await fetch(request);
    if (isCacheableAssetResponse(networkResponse)) {
        await cache.put(request, networkResponse.clone());
    }
    return networkResponse;
}

self.addEventListener('activate', (event) => {
    event.waitUntil((async () => {
        if (self.registration.navigationPreload) {
            await self.registration.navigationPreload.enable();
        }
        const keys = await caches.keys();
        await Promise.all(
            keys
                .filter((key) => shouldDeleteOnActivate(key))
                .map((key) => caches.delete(key))
        );
        await self.clients.claim();
    })());
});

self.addEventListener('message', (event) => {
    if (event.data && event.data.type === 'SKIP_WAITING') {
        self.skipWaiting();
        return;
    }

    if (event.data && event.data.type === 'WARM_NAV_BATCH' && Array.isArray(event.data.urls)) {
        event.waitUntil(warmNavigationUrls(event.data.urls));
    }
});

self.addEventListener('fetch', (event) => {
    const { request } = event;
    const pathname = getRequestPathname(request);
    if (!pathname) return;

    if (isHtmlDocumentRequest(request)) {
        const route = getMatchingRoute('navigation', pathname);
        if (!shouldHandleRoute(route)) return;

        const preloadResponsePromise = request.mode === 'navigate' ? event.preloadResponse : null;
        event.respondWith(handleNavigationRequest(request, preloadResponsePromise));
        return;
    }

    if (!isEligibleAssetRequest(request)) return;

    const route = getMatchingRoute('asset', pathname);
    if (!shouldHandleRoute(route)) return;

    event.respondWith((async () => {
        try {
            return await handleAssetRequest(request, pathname);
        } catch (error) {
            return fetch(request);
        }
    })());
});
