const NAVIGATION_CACHE_PREFIX = 'nav-html-';
const ASSET_CACHE_PREFIX = 'asset-static-';
const FINGERPRINT_ASSET_CACHE = 'asset-fingerprint';
const NAVIGATION_CACHE = NAVIGATION_CACHE_PREFIX + '{{ .build_version }}';
const ASSET_CACHE = ASSET_CACHE_PREFIX + '{{ .build_version }}';
const CACHE_FIRST_EXTENSIONS = {{ .cache_first_extensions | jsonify }};
const navigationWarmupTasks = new Map();

function isSameOriginRequest(request) {
    try {
        return new URL(request.url).origin === self.location.origin;
    } catch (error) {
        return false;
    }
}

function acceptsHtmlDocument(request) {
    try {
        const accept = request.headers.get('accept') || '';
        return accept.includes('text/html');
    } catch (error) {
        return false;
    }
}

function isHtmlDocumentRequest(request) {
    if (request.method !== 'GET') return false;
    if (!isSameOriginRequest(request)) return false;
    if (request.mode === 'navigate') return true;
    if (request.destination === 'document') return true;
    return acceptsHtmlDocument(request);
}

function isCacheableHtmlResponse(response) {
    return response && response.ok && response.headers.get('content-type')?.includes('text/html');
}

function isCacheableAssetResponse(response) {
    return response && response.ok;
}

function getRequestPathname(request) {
    try {
        return new URL(request.url).pathname.toLowerCase();
    } catch (error) {
        return '';
    }
}

function getRequestExtension(request) {
    try {
        const pathname = getRequestPathname(request);
        const match = pathname.match(/\.([a-z0-9]+)$/);
        return match ? match[1] : '';
    } catch (error) {
        return '';
    }
}

function isEligibleAssetRequest(request) {
    if (request.method !== 'GET') return false;
    if (!isSameOriginRequest(request)) return false;
    if (isHtmlDocumentRequest(request)) return false;
    return true;
}

function hasFingerprintInPath(pathname) {
    return /\.[0-9a-f]{8,}\.[^./]+$/i.test(pathname);
}

function isFingerprintAssetRequest(request) {
    if (!isEligibleAssetRequest(request)) return false;
    return hasFingerprintInPath(getRequestPathname(request));
}

function isConfiguredCacheFirstAssetRequest(request) {
    if (!CACHE_FIRST_EXTENSIONS.length) return false;
    if (!isEligibleAssetRequest(request)) return false;
    return CACHE_FIRST_EXTENSIONS.includes(getRequestExtension(request));
}

function shouldHandleAssetRequest(request) {
    return isFingerprintAssetRequest(request) || isConfiguredCacheFirstAssetRequest(request);
}

function getAssetCacheName(request) {
    return isFingerprintAssetRequest(request) ? FINGERPRINT_ASSET_CACHE : ASSET_CACHE;
}

function isManagedCacheKey(key) {
    return key === FINGERPRINT_ASSET_CACHE || key.startsWith(NAVIGATION_CACHE_PREFIX) || key.startsWith(ASSET_CACHE_PREFIX);
}

async function fetchNavigationResponse(request, preloadResponsePromise) {
    if (preloadResponsePromise) {
        try {
            const preloadResponse = await preloadResponsePromise;
            if (preloadResponse) return preloadResponse;
        } catch (error) { }
    }

    return fetch(request);
}

function normalizeWarmNavigationUrl(urlValue) {
    try {
        const url = new URL(urlValue, self.location.origin);
        if (url.origin !== self.location.origin) return '';
        url.hash = '';
        return url.toString();
    } catch (error) {
        return '';
    }
}

async function updateNavigationCache(request, cache, preloadResponsePromise) {
    try {
        let response = await fetchNavigationResponse(request, preloadResponsePromise);
        if (response && response.status === 304) {
            // Browser-level prefetch often revalidates from HTTP cache and returns 304.
            // SW cache needs a full body, so retry by bypassing the browser cache layer.
            response = await fetch(new Request(request, { cache: 'reload' }));
        }
        if (isCacheableHtmlResponse(response)) {
            await cache.put(request, response.clone());
        }
        return response;
    } catch (error) {
        return null;
    }
}

async function warmNavigationUrl(urlValue) {
    const href = normalizeWarmNavigationUrl(urlValue);
    if (!href) return;

    if (navigationWarmupTasks.has(href)) {
        await navigationWarmupTasks.get(href);
        return;
    }

    const task = (async () => {
        const cache = await caches.open(NAVIGATION_CACHE);
        const request = new Request(href, {
            credentials: 'same-origin',
            headers: {
                Accept: 'text/html'
            }
        });
        const cachedResponse = await cache.match(request);
        if (cachedResponse) return;
        await updateNavigationCache(request, cache, null);
    })();

    navigationWarmupTasks.set(href, task);
    try {
        await task;
    } finally {
        navigationWarmupTasks.delete(href);
    }
}

async function warmNavigationUrls(urlValues) {
    for (const urlValue of urlValues) {
        await warmNavigationUrl(urlValue);
    }
}

async function handleNavigationRequest(request, preloadResponsePromise) {
    const cache = await caches.open(NAVIGATION_CACHE);
    const cachedResponse = await cache.match(request);
    if (cachedResponse) {
        return cachedResponse;
    }

    const networkResponse = await updateNavigationCache(request, cache, preloadResponsePromise);
    if (networkResponse) {
        return networkResponse;
    }

    throw new Error('Navigation request failed with no cached response.');
}

async function handleAssetRequest(request) {
    const cache = await caches.open(getAssetCacheName(request));
    const cachedResponse = await cache.match(request);
    if (cachedResponse) return cachedResponse;

    const networkResponse = await fetch(request);
    if (isCacheableAssetResponse(networkResponse)) {
        await cache.put(request, networkResponse.clone());
    }
    return networkResponse;
}

self.addEventListener('activate', (event) => {
    event.waitUntil((async () => {
        if (self.registration.navigationPreload) {
            await self.registration.navigationPreload.enable();
        }
        const keys = await caches.keys();
        await Promise.all(
            keys
                .filter((key) => key.startsWith(NAVIGATION_CACHE_PREFIX) || key.startsWith(ASSET_CACHE_PREFIX))
                .filter((key) => key !== NAVIGATION_CACHE && key !== ASSET_CACHE)
                .map((key) => caches.delete(key))
        );
        await self.clients.claim();
    })());
});

self.addEventListener('message', (event) => {
    if (event.data && event.data.type === 'SKIP_WAITING') {
        self.skipWaiting();
        return;
    }

    if (event.data && event.data.type === 'WARM_NAV_BATCH' && Array.isArray(event.data.urls)) {
        event.waitUntil(warmNavigationUrls(event.data.urls));
    }
});

self.addEventListener('fetch', (event) => {
    const { request } = event;
    if (isHtmlDocumentRequest(request)) {
        const preloadResponsePromise = request.mode === 'navigate' ? event.preloadResponse : null;
        event.respondWith(handleNavigationRequest(request, preloadResponsePromise));
        return;
    }

    if (shouldHandleAssetRequest(request)) {
        event.respondWith(handleAssetRequest(request));
    }
});
